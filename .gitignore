# DATA STORAGE CONFIGURATION
# =========================
# ALL DATA MUST BE STORED IN:
# 1. MinIO Object Storage (primary data lake)
# 2. PostgreSQL Database (indexed records)
# 3. DO NOT commit local data files
# =========================

# Raw data files (CSV, JSON, Parquet, etc)
data/raw/*.json
data/raw/*.csv
data/raw/*.parquet
data/raw/*.avro
data/raw/*.xlsx
data/raw/*.xls

# Processed data files
data/processed/*.json
data/processed/*.csv
data/processed/*.parquet
data/processed/*.avro

# MinIO data directory (local backend storage)
data/minio/
minio_data/
minio/

# Temporary and cache files
*.tmp
*.temp
*.cache
temp/
cache/
*.bak
*.swp

# Database files
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# Environment configuration
.env
.env.local
.env.*.local
config/.env.local

# OS files
Thumbs.db
.DS_Store

# Project specific
notebooks/output/
notebooks/data/
/docs/_build/

# Keep directory structure with .gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!logs/.gitkeep
!src/database/.gitkeep
